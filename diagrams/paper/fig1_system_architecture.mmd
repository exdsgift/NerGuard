sequenceDiagram
    participant Text as Input Text
    participant Tok as Tokenizer
    participant Model as mDeBERTa-v3
    participant Unc as Uncertainty
    participant Router as Router
    participant LLM as LLM
    participant Out as Output

    Text->>Tok: raw text
    Tok->>Model: tokens (≤512)
    Model->>Unc: logits z

    Note over Unc: p = softmax(z)<br/>H = entropy(p)<br/>c = max(p)

    alt H ≤ θ_H or c ≥ θ_c
        Unc-->>Out: ŷ_model (confident)
    else H > θ_H and c < θ_c
        Unc->>Router: uncertain token

        alt BLOCKED entity
            Router-->>Out: ŷ_model
        else ROUTABLE entity
            Router->>LLM: context + token
            LLM-->>Router: ŷ_llm

            alt BIO valid
                Router->>Out: ŷ_llm
            else BIO invalid
                Router-->>Out: ŷ_model
            end
        end
    end

    Note over Out: BIO decode → Entities
