flowchart TB
    subgraph Core["Core Layer"]
        direction TB
        Constants["<b>constants.py</b><br/>───────────────<br/>• DEFAULT_ENTROPY_THRESHOLD: 0.583<br/>• DEFAULT_CONFIDENCE_THRESHOLD: 0.787<br/>• ROUTABLE_ENTITIES<br/>• BLOCKED_ENTITIES<br/>• NVIDIA_TO_MODEL_MAP"]

        Metrics["<b>metrics.py</b><br/>───────────────<br/>• compute_entropy_confidence()<br/>• Shannon entropy: H = -Σp·log(p)<br/>• Confidence: max(softmax)"]

        ModelLoader["<b>model_loader.py</b><br/>───────────────<br/>• load_model_and_tokenizer()<br/>• load_labels()<br/>• get_device()"]

        LabelMapper["<b>label_mapper.py</b><br/>───────────────<br/>• NVIDIA → Model mapping<br/>• BIO tag conversion<br/>• get_token_label_id()"]
    end

    subgraph Inference["Inference Layer"]
        direction TB
        PIITester["<b>PIITester</b><br/>tester.py<br/>───────────────<br/>+ analyze_text(text, lang)<br/>+ get_entities()<br/>+ redact_text()<br/>───────────────<br/>- _process_chunk()<br/>- _handle_sliding_window()"]

        LLMRouter["<b>LLMRouter</b><br/>llm_router.py<br/>───────────────<br/>+ disambiguate()<br/>+ should_route()<br/>───────────────<br/>- _call_openai()<br/>- _call_ollama()<br/>- _validate_response()<br/>- _extract_context()"]

        EntityRouter["<b>EntitySpecificRouter</b><br/>entity_router.py<br/>───────────────<br/>+ should_route()<br/>+ get_stats()<br/>───────────────<br/>ROUTABLE:<br/>CREDITCARD, TELEPHONE,<br/>EMAIL, DATE, SOCIALNUM<br/>───────────────<br/>BLOCKED:<br/>GIVENNAME, SURNAME,<br/>TITLE, CITY, STREET"]

        LLMCache["<b>LLMCache</b><br/>llm_router.py<br/>───────────────<br/>+ get(token, context, ...)<br/>+ set(token, context, result)<br/>───────────────<br/>Key: MD5 hash<br/>Eviction: FIFO<br/>Max size: 1000"]

        Prompts["<b>prompts.py</b><br/>───────────────<br/>• PROMPT_V3 → V12<br/>• Default: PROMPT_V9<br/>• BIO validation rules<br/>• Context extraction"]
    end

    subgraph Evaluation["Evaluation Layer"]
        direction TB
        HybridEval["<b>HybridEvaluator</b><br/>hybrid_evaluator.py<br/>───────────────<br/>+ evaluate_comparison()<br/>+ _tokenize_and_align()<br/>+ _generate_comparison_report()<br/>───────────────<br/>Inherits: PlottingMixin"]

        NvidiaEval["<b>NvidiaEvaluator</b><br/>nvidia_evaluator.py<br/>───────────────<br/>+ evaluate()<br/>+ process_example()<br/>───────────────<br/>Dataset: NVIDIA/Nemotron-PII"]

        Benchmark["<b>Benchmark</b><br/>benchmark.py<br/>───────────────<br/>+ run_benchmark()<br/>───────────────<br/>Models:<br/>• NerGuard (Base/Hybrid)<br/>• SpaCy<br/>• Presidio<br/>• GLiNER"]

        Ablation["<b>AblationRunner</b><br/>ablation_study.py<br/>───────────────<br/>Study 1: Uncertainty Measures<br/>Study 2: Threshold Sensitivity<br/>Study 3: Routing Strategies"]

        MultiSeed["<b>MultiSeedEvaluator</b><br/>multi_seed_benchmark.py<br/>───────────────<br/>Seeds: [42, 123, 456, 789, 999]<br/>• paired_ttest()<br/>• bootstrap_ci()<br/>• 95% confidence intervals"]

        Multilingual["<b>MultilingualEvaluator</b><br/>multilingual.py<br/>───────────────<br/>Languages: en, it, es, de,<br/>fr, pt, nl, pl<br/>Dataset: WikiNeural"]
    end

    subgraph Optimization["Optimization Layer"]
        direction TB
        ThresholdOpt["<b>ThresholdOptimizer</b><br/>threshold_optimizer.py<br/>───────────────<br/>+ vectorized_grid_search()<br/>+ bootstrap_metric()<br/>+ collect_inference_stats_batched()<br/>───────────────<br/>Grid: 30×30 = 900 combinations<br/>Metric: F0.5 Score<br/>Bootstrap: 1000 resamples<br/>Economic: LLM vs Error cost"]
    end

    subgraph Visualization["Visualization Layer"]
        direction TB
        PlottingMixin["<b>PlottingMixin</b><br/>plotting_mixin.py<br/>───────────────<br/>+ _plot_per_class_improvements()<br/>+ _plot_confidence_entropy_analysis()<br/>+ _plot_llm_impact_analysis()<br/>+ _plot_error_analysis()<br/>+ _plot_confusion_matrices()"]

        Style["<b>style.py</b><br/>───────────────<br/>+ set_publication_style()<br/>───────────────<br/>DPI: 300<br/>Font: Helvetica<br/>Grid: alpha=0.3"]

        OptPlots["<b>optimization_plots.py</b><br/>───────────────<br/>+ plot_optimization_heatmap()<br/>+ plot_pareto_frontier()<br/>+ plot_quantization_metrics()"]

        BenchPlots["<b>benchmark_plots.py</b><br/>───────────────<br/>+ plot_main_metrics()<br/>+ plot_efficiency_frontier()<br/>+ plot_entity_comparison()"]
    end

