---
title: NerGuard Evaluation System Architecture
---
flowchart TB
    subgraph Datasets["External Datasets"]
        direction LR
        NVIDIA["<b>NVIDIA/Nemotron-PII</b><br/>─────────────────<br/>Split: train<br/>Fields: text, spans (JSON)<br/>Labels: first_name, phone_number,<br/>credit_card, ssn, email, ..."]

        MultiNERD["<b>Babelscape/MultiNERD</b><br/>─────────────────<br/>Split: validation<br/>NER benchmark dataset"]

        WikiNeural["<b>WikiNeural</b><br/>─────────────────<br/>8 Languages:<br/>en, it, es, de, fr, pt, nl, pl<br/>Labels: PER, LOC, ORG, MISC"]
    end

    subgraph LabelMapping["Label Preprocessing"]
        LabelMapper["<b>LabelMapper</b><br/>label_mapper.py<br/>─────────────────<br/>NVIDIA → Model Mapping:<br/>• first_name → GIVENNAME<br/>• phone_number → TELEPHONENUM<br/>• credit_card → CREDITCARDNUMBER<br/>• ssn → SOCIALNUM<br/>─────────────────<br/>BIO Tag Conversion:<br/>• is_start=True → B-TAG<br/>• is_start=False → I-TAG"]
    end

    subgraph Evaluators["Evaluator Classes"]
        direction TB

        subgraph HybridBlock["HybridEvaluator (hybrid_evaluator.py)"]
            HybridEval["<b>HybridEvaluator</b><br/>─────────────────<br/>Inherits: PlottingMixin<br/>─────────────────<br/>+ evaluate_comparison()<br/>+ _tokenize_and_align()<br/>+ _evaluate_single_sample()<br/>+ _generate_comparison_report()"]

            EvalConfig["<b>EvalConfig</b><br/>─────────────────<br/>model_path: str<br/>output_dir: str<br/>max_samples: 1000<br/>context_length: 512<br/>THRESHOLD_ENTROPY: 0.583<br/>THRESHOLD_CONF: 0.787<br/>use_selective_routing: True<br/>block_continuation_tokens: True"]

            HybridResult["<b>HybridResult</b><br/>─────────────────<br/>true_ids: List[int]<br/>baseline_preds: List[int]<br/>hybrid_preds: List[int]<br/>llm_calls: int<br/>llm_corrections: int<br/>llm_wrong_corrections: int<br/>confidence_scores: List[float]<br/>entropy_scores: List[float]<br/>per_class_stats: Dict"]
        end

        subgraph NvidiaBlock["NvidiaEvaluator (nvidia_evaluator.py)"]
            NvidiaEval["<b>NvidiaEvaluator</b><br/>─────────────────<br/>+ evaluate()<br/>+ process_example()<br/>+ _plot_cm()<br/>+ _plot_efficiency_frontier()"]

            NvidiaOutput["<b>Outputs</b><br/>─────────────────<br/>• Classification report<br/>• Confusion matrix<br/>• Efficiency frontier plot<br/>• Per-class metrics"]
        end

        subgraph BenchmarkBlock["Benchmark System (benchmark.py)"]
            Benchmark["<b>run_benchmark()</b><br/>─────────────────<br/>Compare multiple models<br/>on same dataset"]

            ModelWrapper["<b>ModelWrapper</b> (Abstract)<br/>─────────────────<br/>+ predict(sample, tokenizer, id2label)<br/>+ name: str"]

            NerGuardWrapper["<b>NerGuard</b><br/>─────────────────<br/>• Base Mode<br/>  (enable_llm=False)<br/>• Hybrid Mode<br/>  (enable_llm=True)<br/>• Hybrid+Selective<br/>  (use_selective_routing=True)"]

            ExternalWrapper["<b>ExternalWrapper</b><br/>─────────────────<br/>• SpaCy (en_core_web_lg)<br/>• Presidio (AnalyzerEngine)<br/>• GLiNER (gliner_multi-v2.1)"]
        end
    end

    subgraph AdvancedStudies["Advanced Evaluation Studies"]
        direction TB

        AblationBlock["<b>AblationRunner</b><br/>ablation_study.py<br/>─────────────────<br/><b>Study 1: Uncertainty Measures</b><br/>• Entropy Only<br/>• Confidence Only<br/>• Combined (E+C)<br/>─────────────────<br/><b>Study 2: Threshold Sensitivity</b><br/>• Low: E=0.3, C=0.6<br/>• Medium: E=0.5, C=0.7<br/>• Default: E=0.583, C=0.787<br/>• High: E=0.7, C=0.85<br/>• Very High: E=0.9, C=0.95<br/>─────────────────<br/><b>Study 3: Routing Strategies</b><br/>• No Selective Routing<br/>• Selective Only<br/>• Selective + I-Block"]

        MultiSeedBlock["<b>MultiSeedEvaluator</b><br/>multi_seed_benchmark.py<br/>─────────────────<br/>Seeds: [42, 123, 456, 789, 999]<br/>─────────────────<br/><b>Statistical Methods:</b><br/>• paired_ttest(model_a, model_b)<br/>  → t-stat, p-value, Cohen's d<br/>• bootstrap_ci(metric, n=1000)<br/>  → 95% confidence interval<br/>─────────────────<br/><b>Output Format:</b><br/>mean ± std [CI_low, CI_high]"]

        MultilingualBlock["<b>MultilingualEvaluator</b><br/>multilingual.py<br/>─────────────────<br/><b>Languages:</b><br/>• Germanic: en, de, nl<br/>• Romance: it, es, fr, pt<br/>• Slavic: pl<br/>─────────────────<br/><b>Analysis:</b><br/>• Per-language F1<br/>• Transfer degradation<br/>• Language family grouping"]
    end

    subgraph Pipeline["Evaluation Pipeline Flow"]
        direction TB

        LoadData["1. Load Dataset<br/>load_dataset() / load_from_disk()"]

        TokenizeAlign["2. Tokenize & Align Labels<br/>─────────────────<br/>• Offset mapping<br/>• BIO tag assignment<br/>• -100 masking for special tokens"]

        RunInference["3. Run Model Inference<br/>─────────────────<br/>• Forward pass → logits<br/>• Softmax → probabilities<br/>• Compute entropy/confidence<br/>• Argmax → predictions"]

        RoutingDecision["4. Routing Decision<br/>(if hybrid mode)<br/>─────────────────<br/>• Check uncertainty thresholds<br/>• Check entity type<br/>• Route to LLM if needed"]

        ComputeMetrics["5. Compute Metrics<br/>─────────────────<br/>• sklearn.classification_report()<br/>• Precision, Recall, F1<br/>• Per-class breakdown<br/>• Confusion matrix"]

        GenerateOutput["6. Generate Output<br/>─────────────────<br/>• Text reports<br/>• JSON metrics<br/>• Visualization plots"]
    end

    subgraph Outputs["Evaluation Outputs"]
        direction LR

        TextReports["<b>Text Reports</b><br/>─────────────────<br/>comparison_report.txt<br/>evaluation_report.txt<br/>ablation_report.txt<br/>multi_seed_report.txt"]

        JSONMetrics["<b>JSON Metrics</b><br/>─────────────────<br/>metrics.json<br/>results.json<br/>ablation_results.json<br/>multi_seed_results.json"]

        Plots["<b>Visualization Plots</b><br/>─────────────────<br/>confusion_matrix_comparison.png<br/>per_class_improvements.png<br/>confidence_entropy_analysis.png<br/>llm_impact_analysis.png<br/>error_analysis.png<br/>efficiency_frontier.png"]
    end

    %% Dataset connections
    NVIDIA --> LabelMapper
    LabelMapper --> HybridEval
    LabelMapper --> NvidiaEval

    MultiNERD --> Benchmark
    WikiNeural --> MultilingualBlock

    %% Evaluator internal connections
    HybridEval --> EvalConfig
    HybridEval --> HybridResult
    NvidiaEval --> NvidiaOutput

    Benchmark --> ModelWrapper
    ModelWrapper --> NerGuardWrapper
    ModelWrapper --> ExternalWrapper

    %% Pipeline flow
    LoadData --> TokenizeAlign
    TokenizeAlign --> RunInference
    RunInference --> RoutingDecision
    RoutingDecision --> ComputeMetrics
    ComputeMetrics --> GenerateOutput

    %% Output connections
    HybridEval --> TextReports
    HybridEval --> Plots
    NvidiaEval --> JSONMetrics
    NvidiaEval --> Plots
    AblationBlock --> TextReports
    AblationBlock --> JSONMetrics
    MultiSeedBlock --> JSONMetrics
    Benchmark --> Plots

