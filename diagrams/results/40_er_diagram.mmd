%%{init: {'theme': 'neutral'}}%%
erDiagram
    TOKEN ||--o{ PREDICTION : has
    TOKEN {
        int id
        string text
        int position
    }

    PREDICTION ||--|| UNCERTAINTY : has
    PREDICTION {
        int label_id
        float logit
        string bio_tag
    }

    UNCERTAINTY {
        float entropy
        float confidence
        bool is_uncertain
    }

    PREDICTION ||--o| LLM_QUERY : triggers
    LLM_QUERY {
        string context
        string response
        bool is_valid
        float cost
    }

    TOKEN ||--|| ENTITY : belongs_to
    ENTITY {
        string type
        bool is_routable
        float f1_delta
    }
